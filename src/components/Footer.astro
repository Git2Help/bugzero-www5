        </ul>
      </div>

      <div>
        <h3 class="mb-5 text-xs font-medium uppercase tracking-widest text-[#666]">
          Professionnel
        </h3>
        <ul class="space-y-3 text-sm text-[#a0a0a0]">
          <li><a href="/professionnel/maintenance-pro" class="transition-colors hover:text-white">Formules Maintenance</a></li>
          <li><a href="/professionnel" class="transition-colors hover:text-white">SécuriSite WP Pro</a></li>
          <li><a href="/professionnel/audit-securite" class="transition-colors hover:text-white">Cybersécurité &amp; Audit</a></li>
          <li><a href="/professionnel/creation-site" class="transition-colors hover:text-white">Création de site &amp; SEO</a></li>
          <li><a href="/professionnel/infogerance" class="transition-colors hover:text-white">Infogérance</a></li>
        </ul>
      </div>

      <div>
        <h3 class="mb-5 text-xs font-medium uppercase tracking-widest text-[#666]">
          Particulier
        </h3>
        <ul class="space-y-3 text-sm text-[#a0a0a0]">
          <li><a href="/particulier" class="transition-colors hover:text-white">Dépannage à distance</a></li>
          <li><a href="/particulier" class="transition-colors hover:text-white">Dépannage sur site</a></li>
          <li><a href="/particulier" class="transition-colors hover:text-white">Maintenance préventive</a></li>
          <li><a href="/particulier" class="transition-colors hover:text-white">Formation</a></li>
