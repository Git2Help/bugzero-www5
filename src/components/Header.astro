---
---

<!-- Top Banner -->
<div class="w-full bg-[#0a0a0a] text-white overflow-hidden relative">
  <div class="mx-auto flex min-h-8 max-w-[90rem] items-center justify-center px-4 text-center text-xs font-medium leading-none tracking-wide">
    <span class="mr-2 inline-flex h-1.5 w-1.5 animate-pulse rounded-full bg-[#4f46e5]"></span>
    BUGZERO — Votre partenaire IT à Monaco depuis 2015.
    <a href="/professionnel" class="ml-2 text-[#a5b4fc] transition hover:text-white hover:underline underline-offset-4">
      Découvrir nos services
    </a>
  </div>
</div>

<!-- Navigation -->
<header class="sticky top-0 z-50 border-b border-[#eaeaea] bg-white/80 backdrop-blur-xl transition-all duration-300" id="header">
  <nav class="mx-auto flex h-16 max-w-[90rem] items-center justify-between px-4 sm:px-6 lg:px-8" aria-label="Navigation principale">
    <div class="flex items-center gap-12">
      <a href="/" class="flex items-center text-base font-semibold tracking-tight text-[#0a0a0a]" aria-label="Accueil">
        BUGZERO
      </a>

      <div class="hidden items-center gap-2 lg:flex">
        <a href="/professionnel" class="flex min-h-11 items-center rounded-full px-4 text-sm font-medium text-[#4a4a4a] transition hover:bg-[#f4f4f5] hover:text-[#0a0a0a]">
          Professionnel
        </a>
        <a href="/particulier" class="flex min-h-11 items-center rounded-full px-4 text-sm font-medium text-[#4a4a4a] transition hover:bg-[#f4f4f5] hover:text-[#0a0a0a]">
          Particulier
        </a>
      </div>
    </div>

    <div class="hidden items-center gap-4 lg:flex">
      <a href="#contact" class="group relative inline-flex items-center justify-center overflow-hidden rounded-full bg-[#0a0a0a] px-6 py-2.5 text-sm font-medium text-white transition-all hover:bg-[#1a1a1a]">
        <span class="relative z-10">Nous contacter</span>
        <div class="absolute inset-0 -translate-x-full bg-gradient-to-r from-[#4f46e5] to-[#7c3aed] transition-transform duration-500 ease-out group-hover:translate-x-0"></div>
        <span class="relative z-10 ml-2 block transition-transform duration-300 group-hover:translate-x-1">
          <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
        </span>
      </a>
    </div>

    <button id="mobileMenuButton" class="flex h-10 w-10 items-center justify-center rounded-full border border-[#eaeaea] lg:hidden hover:bg-[#f4f4f5] transition" aria-label="Menu" aria-expanded="false">
      <iconify-icon icon="solar:hamburger-menu-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
    </button>
  </nav>
</header>