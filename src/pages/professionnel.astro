---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="BUGZERO | Services IT professionnels à Monaco — infogérance, cybersécurité, web" description="Infogérance, cybersécurité, sites web et SEO pour TPE/PME à Monaco. Service IT sur-mesure dès 59€ HT/mois, sans recruter.">
  <fragment slot="header">
    <Header />
  </fragment>

  <style>
    @keyframes kineticReveal {
      0% { opacity: 0; transform: translateZ(-800px) translateY(80px) rotateX(30deg) scale(0.8); filter: blur(12px); letter-spacing: -0.1em; }
      60% { opacity: 1; transform: translateZ(50px) translateY(-10px) rotateX(-5deg) scale(1.02); filter: blur(0px); letter-spacing: -0.04em; }
      100% { opacity: 1; transform: translateZ(0) translateY(0) rotateX(0deg) scale(1); filter: blur(0px); letter-spacing: -0.05em; }
    }
    @keyframes liquidFlow {
      0% { background-position: 0% 50%; }
      50% { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    @keyframes chromaticOffset {
      0% { transform: translate(-3px, -2px) scale(1.01); filter: hue-rotate(0deg) blur(2px); }
      100% { transform: translate(3px, 2px) scale(1.01); filter: hue-rotate(45deg) blur(3px); }
    }
    .animate-kinetic { animation: kineticReveal 1.8s cubic-bezier(0.19, 1, 0.22, 1) forwards; opacity: 0; transform-style: preserve-3d; display: inline-block; will-change: transform, opacity, filter; }
    .text-liquid { background: linear-gradient(110deg, #050505 0%, #4f46e5 25%, #7c3aed 50%, #2563eb 75%, #050505 100%); background-size: 200% auto; color: transparent; -webkit-background-clip: text; background-clip: text; animation: liquidFlow 4s linear infinite; }
    .text-aura { position: absolute; inset: -20px; background: linear-gradient(90deg, rgba(79,70,229,0.3), rgba(124,58,237,0.3), rgba(37,99,235,0.3)); filter: blur(30px); z-index: -1; opacity: 0; animation: auraReveal 2s 1s ease-out forwards, liquidFlow 4s linear infinite; border-radius: 50%; }
    @keyframes auraReveal { to { opacity: 0.8; } }
  </style>

  <!-- 1. Hero -->
  <section class="overflow-hidden lg:pt-36 lg:pb-48 bg-[#fcfcfc] pt-24 pb-32 relative">
    <div class="absolute inset-0 z-0 pointer-events-none overflow-hidden flex justify-center">
      <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[70vw] h-[70vw] rounded-full bg-[radial-gradient(circle_at_center,rgba(79,70,229,0.12)_0%,transparent_60%)] blur-[100px]"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-[#fcfcfc]/30 via-[#fcfcfc]/80 to-[#fcfcfc]"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-[90rem] px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center">
      <div class="scroll-reveal revealed" style="transition-delay: 100ms;">
        <div class="mb-8 inline-flex items-center rounded-full border border-[#e5e5e5] bg-white/60 px-4 py-1.5 text-xs font-medium text-[#171717] shadow-sm backdrop-blur-md">
          <span class="relative flex h-2 w-2 mr-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4f46e5] opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-[#4f46e5]"></span>
          </span>
          Partenaire IT des entreprises à Monaco &amp; PACA
        </div>
      </div>
      <div style="perspective: 1200px;" class="max-w-5xl mt-2 mb-2">
        <h1 class="text-[clamp(3.5rem,8vw,8.5rem)] font-medium leading-[0.95] tracking-tighter text-[#050505] flex flex-col items-center" style="transform-style: preserve-3d;">
          <span class="block animate-kinetic" style="animation-delay: 200ms;">Informatique</span>
          <span class="block animate-kinetic" style="animation-delay: 400ms;">
            <span class="relative inline-block">
              <span class="text-liquid inline-block pb-1 pr-2 relative z-10">sur-mesure</span>
              <span class="absolute inset-0 text-liquid pb-1 pr-2 z-0 mix-blend-multiply opacity-60" style="animation: liquidFlow 4s linear infinite, chromaticOffset 3s ease-in-out infinite alternate;">sur-mesure</span>
              <span class="text-aura"></span>
            </span>
          </span>
          <span class="block animate-kinetic" style="animation-delay: 600ms;">sans recruter.</span>
        </h1>
      </div>
      <div class="mt-8 max-w-2xl scroll-reveal revealed" style="transition-delay: 800ms;">
        <p class="text-base leading-relaxed text-[#4a4a4a] sm:text-lg lg:text-xl">
          Infogérance, cybersécurité, sites web et SEO pour TPE/PME. Concentrez-vous sur votre business. Dès 59€ HT/mois.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/professionnel/maintenance-pro" class="group flex w-full sm:w-auto items-center justify-center gap-2 rounded-full bg-[#0a0a0a] px-8 py-3.5 text-sm font-medium text-white transition-all hover:bg-[#1a1a1a] hover:shadow-xl hover:shadow-black/10 hover:-translate-y-0.5">
            Voir les formules
            <svg class="h-4 w-4 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"></path><path d="M7 7h10v10"></path></svg>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Formules Maintenance -->
  <section class="bg-[#fcfcfc]">
    <div class="mx-auto max-w-[90rem] px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="text-center mb-16 scroll-reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/80 border border-[#eaeaea] mb-6 backdrop-blur-md shadow-sm">
          <div class="w-1.5 h-1.5 rounded-full bg-[#4f46e5] animate-pulse"></div>
          <span class="text-xs text-[#666] tracking-widest uppercase font-medium">Forfaits</span>
        </div>
        <h2 class="text-[clamp(2.4rem,4.5vw,5rem)] font-medium leading-[1] tracking-tighter mb-4 text-[#0a0a0a]">Formules de maintenance</h2>
        <p class="text-base text-[#666] max-w-md mx-auto">Quatre formules claires, sans engagement. Vous montez ou descendez quand vous voulez.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4 max-w-6xl mx-auto">
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 flex flex-col transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal">
          <div class="mb-6"><iconify-icon icon="solar:server-square-cloud-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon></div>
          <h3 class="text-lg font-medium tracking-tight mb-2">Supervision-Assistance</h3>
          <div class="flex items-end gap-1 mb-4"><span class="text-4xl tracking-tighter text-[#0a0a0a] font-medium">79€</span><span class="text-xs text-[#666] mb-1.5 tracking-widest uppercase">HT/mois</span></div>
          <p class="text-sm leading-relaxed text-[#666] mb-6 flex-grow">Supervision 24/7 + Bitdefender + MSP360. Pour les indépendants.</p>
          <a href="/professionnel/maintenance-pro" class="mt-auto w-full py-3 px-4 rounded-xl flex items-center justify-between group/btn transition-all duration-300 hover:bg-[#f4f4f5] bg-white border border-[#eaeaea] shadow-sm">
            <span class="text-xs text-[#0a0a0a] tracking-widest uppercase font-semibold">Choisir</span>
            <iconify-icon icon="solar:alt-arrow-right-linear" class="text-[#4f46e5] text-lg group-hover/btn:translate-x-1 transition-transform"></iconify-icon>
          </a>
        </div>
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 flex flex-col transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal" style="transition-delay: 100ms;">
          <div class="mb-6"><iconify-icon icon="solar:headphones-round-sound-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon></div>
          <h3 class="text-lg font-medium tracking-tight mb-2">Liberté</h3>
          <div class="flex items-end gap-1 mb-4"><span class="text-4xl tracking-tighter text-[#0a0a0a] font-medium">99€</span><span class="text-xs text-[#666] mb-1.5 tracking-widest uppercase">HT/mois</span></div>
          <p class="text-sm leading-relaxed text-[#666] mb-6 flex-grow">+1 appel mensuel (30 min), 6 tickets, assistance à distance.</p>
          <a href="/professionnel/maintenance-pro" class="mt-auto w-full py-3 px-4 rounded-xl flex items-center justify-between group/btn transition-all duration-300 hover:bg-[#f4f4f5] bg-white border border-[#eaeaea] shadow-sm">
            <span class="text-xs text-[#0a0a0a] tracking-widest uppercase font-semibold">Choisir</span>
            <iconify-icon icon="solar:alt-arrow-right-linear" class="text-[#4f46e5] text-lg group-hover/btn:translate-x-1 transition-transform"></iconify-icon>
          </a>
        </div>
        <div class="rounded-2xl bg-gradient-to-br from-[#0a0a0a] to-[#141414] border border-white/10 p-8 flex flex-col transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/20 hover:-translate-y-1 scroll-reveal relative overflow-hidden" style="transition-delay: 200ms;">
          <div class="absolute -top-16 -right-16 w-40 h-40 bg-[#4f46e5] rounded-full blur-[60px] opacity-20 pointer-events-none"></div>
          <div class="absolute top-6 right-6 flex items-center gap-1.5 text-[#a5b4fc] font-medium text-xs"><iconify-icon icon="solar:star-bold" class="text-sm"></iconify-icon><span class="tracking-tight uppercase">Populaire</span></div>
          <div class="mb-6"><iconify-icon icon="solar:rocket-2-linear" stroke-width="1.5" class="text-3xl text-[#a5b4fc]"></iconify-icon></div>
          <h3 class="text-lg font-medium tracking-tight mb-2 text-white">Puissance</h3>
          <div class="flex items-end gap-1 mb-4"><span class="text-4xl tracking-tighter text-white font-medium">149€</span><span class="text-xs text-white/50 mb-1.5 tracking-widest uppercase">HT/mois</span></div>
          <p class="text-sm leading-relaxed text-[#a0a0a0] mb-6 flex-grow">+3 appels/mois, 3h sur site à Monaco et PACA.</p>
          <a href="/professionnel/maintenance-pro" class="mt-auto w-full py-3 px-4 rounded-xl flex items-center justify-between group/btn transition-all duration-300 hover:bg-white/10 bg-[#1a1a1a] border border-white/10 shadow-sm">
            <span class="text-xs text-white tracking-widest uppercase font-semibold">Choisir</span>
            <iconify-icon icon="solar:alt-arrow-right-linear" class="text-white text-lg group-hover/btn:translate-x-1 transition-transform"></iconify-icon>
          </a>
        </div>
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 flex flex-col transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal" style="transition-delay: 300ms;">
          <div class="mb-6"><iconify-icon icon="solar:medal-ribbon-star-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon></div>
          <h3 class="text-lg font-medium tracking-tight mb-2">Illimitée</h3>
          <div class="flex items-end gap-1 mb-4"><span class="text-4xl tracking-tighter text-[#0a0a0a] font-medium">249€</span><span class="text-xs text-[#666] mb-1.5 tracking-widest uppercase">HT/mois</span></div>
          <p class="text-sm leading-relaxed text-[#666] mb-6 flex-grow">Appels illimités, 1 journée sur site par mois.</p>
          <a href="/professionnel/maintenance-pro" class="mt-auto w-full py-3 px-4 rounded-xl flex items-center justify-between group/btn transition-all duration-300 hover:bg-[#f4f4f5] bg-white border border-[#eaeaea] shadow-sm">
            <span class="text-xs text-[#0a0a0a] tracking-widest uppercase font-semibold">Choisir</span>
            <iconify-icon icon="solar:alt-arrow-right-linear" class="text-[#4f46e5] text-lg group-hover/btn:translate-x-1 transition-transform"></iconify-icon>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. SécuriSite WP Pro -->
  <section class="border-y border-[#eaeaea] bg-white relative overflow-hidden">
    <div class="absolute left-1/2 top-0 h-[1px] w-1/2 -translate-x-1/2 bg-gradient-to-r from-transparent via-[#4f46e5] to-transparent opacity-50"></div>
    <div class="mx-auto max-w-[90rem] px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="text-center mb-16 scroll-reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/80 border border-[#eaeaea] mb-6 backdrop-blur-md shadow-sm">
          <div class="w-1.5 h-1.5 rounded-full bg-[#4f46e5] animate-pulse"></div>
          <span class="text-xs text-[#666] tracking-widest uppercase font-medium">Sécurité Web</span>
        </div>
        <h2 class="text-[clamp(2.4rem,4.5vw,5rem)] font-medium leading-[1] tracking-tighter mb-4 text-[#0a0a0a]">Votre site WordPress inviolable</h2>
        <p class="text-base text-[#666] max-w-lg mx-auto">Mises à jour, sécurité, sauvegardes quotidiennes. Garantie anti-piratage.</p>
      </div>
      <div class="max-w-3xl mx-auto">
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 md:p-10 shadow-sm hover:shadow-2xl hover:shadow-[#4f46e5]/5 transition-all duration-500">
          <div class="flex items-center justify-between mb-8">
            <div>
              <span class="text-5xl tracking-tighter text-[#0a0a0a] font-medium">99€</span>
              <span class="text-sm text-[#666] mb-1 tracking-widest uppercase ml-2">/ Mois HT</span>
            </div>
            <div class="flex items-center gap-1.5 text-[#4f46e5] font-medium text-sm">
              <iconify-icon icon="solar:shield-check-linear" class="text-lg"></iconify-icon>
              <span class="tracking-tight uppercase">Garanti</span>
            </div>
          </div>
          <div class="grid md:grid-cols-2 gap-6">
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Mises à jour WordPress automatiques</span></div>
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Pare-feu applicatif (WAF)</span></div>
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Sauvegarde quotidienne cloud</span></div>
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Scan de vulnérabilités</span></div>
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Monitoring de disponibilité</span></div>
            <div class="flex items-start gap-3 text-sm text-[#4a4a4a]"><iconify-icon icon="solar:check-circle-linear" class="text-[#4f46e5] text-base shrink-0"></iconify-icon><span>Support prioritaire</span></div>
          </div>
          <a href="mailto:bonjour@bugzero.fr" class="mt-10 w-full py-3.5 px-5 rounded-xl flex items-center justify-between group/btn transition-all duration-300 hover:bg-[#f4f4f5] bg-white border border-[#eaeaea] shadow-sm">
            <span class="text-xs text-[#0a0a0a] tracking-widest uppercase font-semibold">Souscrire</span>
            <iconify-icon icon="solar:alt-arrow-right-linear" class="text-[#4f46e5] text-lg group-hover/btn:translate-x-1 transition-transform"></iconify-icon>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Cybersécurité -->
  <section class="bg-[#fcfcfc] relative overflow-hidden border-y border-[#eaeaea]">
    <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZyI+PGNpcmNsZSBjeD0iMSIgY3k9IjEiIHI9IjEiIGZpbGw9InJnYmEoMCwwLDAsMC4wNCkiLz48L3N2Zz4=')] [mask-image:linear-gradient(to_bottom,white_10%,transparent_90%)] pointer-events-none"></div>
    <div class="mx-auto max-w-[90rem] px-4 py-24 sm:px-6 lg:px-8 lg:py-32 relative z-10">
      <div class="text-center mb-16 scroll-reveal">
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white/80 border border-[#eaeaea] mb-6 backdrop-blur-md shadow-sm">
          <div class="w-1.5 h-1.5 rounded-full bg-[#4f46e5] animate-pulse"></div>
          <span class="text-xs text-[#666] tracking-widest uppercase font-medium">Sécurité</span>
        </div>
        <h2 class="text-[clamp(2.4rem,4.5vw,5rem)] font-medium leading-[1] tracking-tighter mb-4 text-[#0a0a0a]">Cybersécurité</h2>
        <p class="text-base text-[#666] max-w-lg mx-auto">Test d'intrusion dès 500€ HT. Rapport complet, conformité RGPD/NIS2.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/professionnel/audit-securite" class="group rounded-2xl bg-white border border-[#eaeaea] p-8 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal block">
          <div class="mb-6">
            <iconify-icon icon="solar:bug-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon>
          </div>
          <h3 class="text-lg font-medium tracking-tight mb-3">Test d'intrusion</h3>
          <p class="text-sm leading-relaxed text-[#666]">Audit de sécurité complet dès 500€ HT. Identification et correction des vulnérabilités avant qu'elles ne soient exploitées.</p>
          <div class="mt-4 flex items-center gap-1.5 text-sm font-medium text-[#4f46e5] transition-all group-hover:gap-2.5">
            Découvrir l'audit
            <iconify-icon icon="solar:arrow-right-linear" stroke-width="1.5"></iconify-icon>
          </div>
        </a>
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal" style="transition-delay: 100ms;">
          <div class="mb-6">
            <iconify-icon icon="solar:shield-check-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon>
          </div>
          <h3 class="text-lg font-medium tracking-tight mb-3">Bitdefender</h3>
          <p class="text-sm leading-relaxed text-[#666]">Solution antivirus et anti-ransomware de nouvelle génération. Protection multi-points pour tous vos postes et serveurs.</p>
        </div>
        <div class="rounded-2xl bg-white border border-[#eaeaea] p-8 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal" style="transition-delay: 200ms;">
          <div class="mb-6">
            <iconify-icon icon="solar:document-text-linear" stroke-width="1.5" class="text-3xl text-[#4f46e5]"></iconify-icon>
          </div>
          <h3 class="text-lg font-medium tracking-tight mb-3">RGPD &amp; NIS2</h3>
          <p class="text-sm leading-relaxed text-[#666]">Mise en conformité avec les réglementations européennes. Audit, documentation et déploiement des mesures techniques nécessaires.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- 5. Visibilité Web -->
  <section class="bg-white border-y border-[#eaeaea]">
    <div class="mx-auto max-w-[90rem] px-4 py-24 sm:px-6 lg:px-8 lg:py-32">
      <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-16 scroll-reveal">
        <div>
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-[#eaeaea] mb-6 shadow-sm">
            <span class="relative flex h-2 w-2"><span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#4f46e5] opacity-75"></span><span class="relative inline-flex rounded-full h-2 w-2 bg-[#4f46e5]"></span></span>
            <span class="text-xs font-medium uppercase tracking-widest text-[#666]">Web</span>
          </div>
          <h2 class="text-[clamp(2.4rem,5vw,4.5rem)] leading-[1] font-medium tracking-tighter max-w-3xl">Visibilité web</h2>
        </div>
        <p class="text-base text-[#666] max-w-sm">Création sur mesure, référencement SEO, Google Ads. Fonds Bleu (30-70% pour Monaco). 2 mois de maintenance offerts.</p>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        <a href="/professionnel/creation-site" class="group relative overflow-hidden rounded-2xl bg-white border border-[#eaeaea] p-2 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal block">
          <div class="relative overflow-hidden rounded-xl bg-[#f4f4f5]">
            <img src="https://hoirqrkdgbmvpwutwuwj.supabase.co/storage/v1/object/public/assets/assets/variants/e44ec1fe-2eb5-4aee-917b-f31f10e9f350/1600w.jpg" alt="Création site" class="aspect-[4/3] w-full object-cover transition-transform duration-700 group-hover:scale-105 filter grayscale-[30%] group-hover:grayscale-0">
            <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
            <div class="absolute bottom-4 left-4 flex h-10 w-10 translate-y-4 items-center justify-center rounded-full bg-white text-[#0a0a0a] opacity-0 transition-all duration-500 group-hover:translate-y-0 group-hover:opacity-100">
              <iconify-icon icon="solar:arrow-right-up-linear" stroke-width="1.5" class="text-xl"></iconify-icon>
            </div>
          </div>
          <div class="p-6">
            <div class="mb-3 flex items-center gap-2"><iconify-icon icon="solar:pen-new-square-linear" stroke-width="1.5" class="text-xl text-[#4f46e5]"></iconify-icon><h3 class="text-lg font-medium tracking-tight">Création de site</h3></div>
            <p class="text-sm leading-relaxed text-[#666]">Sites vitrines, e-commerce ou sur mesure. Design moderne et responsive optimisé pour la conversion.</p>
          </div>
        </a>
        <div class="group relative overflow-hidden rounded-2xl bg-white border border-[#eaeaea] p-2 transition-all duration-500 hover:shadow-2xl hover:shadow-[#4f46e5]/5 hover:-translate-y-1 scroll-reveal" style="transition-delay: 100ms;">
          <div class="relative overflow-hidden rounded-xl bg-[#f4f4f5]">
